{
  "compileOnSave": false,
  "compilerOptions": {
    "strict": true,
    "rootDir": ".",
    "sourceMap": true,
    "declaration": false,
    "moduleResolution": "bundler",
    "emitDecoratorMetadata": true,
    "experimentalDecorators": true,
    "importHelpers": true,
    "target": "es2022",
    "module": "esnext",
    "lib": [
      "es2022",
      "dom"
    ],
    "skipLibCheck": true,
    "skipDefaultLibCheck": true,
    "baseUrl": ".",
    "paths": {
      "@org/api/products": [
        "libs/api/products/src/index.ts"
      ],
      "@org/models": [
        "libs/shared/models/src/index.ts"
      ],
      "@org/shop/data": [
        "libs/shop/data/src/index.ts"
      ],
      "@org/shop/feature-product-detail": [
        "libs/shop/feature-product-detail/src/index.ts"
      ],
      "@org/shop/feature-products": [
        "libs/shop/feature-products/src/index.ts"
      ],
      "@org/shop/shared-ui": [
        "libs/shop/shared-ui/src/index.ts"
      ]
    },
    "forceConsistentCasingInFileNames": true
  },
  "exclude": [
    "node_modules",
    "tmp"
  ]
}